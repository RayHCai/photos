{
    "name": "@photos/backend",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "db:generate": "prisma generate",
        "db:migrate:dev": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "test": "vitest",
        "test:run": "vitest run"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.700.0",
        "@aws-sdk/s3-request-presigner": "^3.700.0",
        "@prisma/client": "^6.3.0",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.30.0",
        "chrono-node": "^2.9.1",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.4.2",
        "express": "^4.21.0",
        "express-rate-limit": "^7.4.0",
        "file-type": "^19.6.0",
        "helmet": "^8.0.0",
        "ioredis": "^5.4.0",
        "multer": "^1.4.5-lts.1",
        "nanoid": "^5.0.9",
        "pino": "^9.5.0",
        "pino-pretty": "^13.0.0",
        "rate-limit-redis": "^4.2.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.15.0",
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.10.0",
        "eslint": "^9.15.0",
        "globals": "^15.12.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.10",
        "prettier": "^3.4.0",
        "prisma": "^6.3.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.15.0",
        "vitest": "^2.1.0"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ]
    }
}
