# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://photos:photos_dev@localhost:5432/photos?connection_limit=20

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=photos-platform

# Auth
SESSION_TTL_DAYS=30
BCRYPT_ROUNDS=12

# Upload
MAX_FILE_SIZE_MB=5000
PRESIGNED_URL_EXPIRY_SECONDS=900

# Search / Worker
WORKER_URL=http://localhost:8001
WORKER_SECRET=
HNSW_EF_SEARCH=100

# Logging
LOG_LEVEL=info
